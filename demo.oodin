/*
	Object Oriented Odin (OOdin);
	OOdin is a super set of the Odin programming language.
	The goal of this project is to create a transpiler that takes
	an OOdin file and converts it into plain odin.

	In this file I will propose syntax for OOdin and how it
	should be converted into Odin.
*/
package OOdin

// OOdin
// We use the new keyword type 'class' using the established Odin type decleration structure.
// A class is essentially just a struct that has functions that are scoped to the struct.
Test :: class {
	// Member variables use struct syntax
	a: i32,
	b: b32,
	c: f32,

	// Class member functions
	// 'init' is the constructor method for all classes.
	// A class doesn't have to have an init method.
	init :: proc(b: b32 /* Params are optional */) {
		// 'this' is a keyword refering to the object the method was called on
		// and is implicitly passed to all member functions. In order to read/write any object
		// fields / call an object method you must use the 'this' keyword (Subject to change).
		this.a = 10
		this.b = b
		this.c = 1.0
	}, // <-- Note you currently must include a comma at the end of the fn def

	// 'uninit' is the name used for destructors.
	uninit :: proc() {
		// Free class.
	},

	// A class can have any number of methods and each method is required to have a function
	// body (excluding abstract classes).
	sub_a :: proc(x: i32) -> i32 {
		return x - this.a
	},
}

// Odin
// A class gets transpiled into the following vanilla Odin code.
Test :: struct {
	a: i32,
	b: b32,
	c: f32,
}

Test___init :: proc(this: ^Test, b: b32) {
	this.a = 10
	this.b = b
	this.c = 1.0
}

Test___uninit :: proc(this: ^Test) {
	// Free class.
}

Test___sub_a :: proc(this: ^Test, x: i32) -> i32 {
	return x - this.a
}

// Class instantiation. Unlike many OOP languages the new keyword isn't necessary
// and should only be used when you want to allocate a pointer. (refer to vanilla odin's new keyword)

// OOdin
t1: Test
t1.init(false)
defer t1.uninit()

t1.sub_a(10)

t2: ^Test = new(Test)
t2.init(false)
defer t2.uninit()

// Odin
t1: Test
Test___init(&t1)
defer Test___uninit(&t1)

Test___sub_a(&t1, 10)

t2: ^Test = new(Test) // You are responsable for calling free on the pointer.
Test___init(&t2)
defer Test___uninit(&t2)

// oodin
// Classes can inherit from other classes using the '#inherit' tag.
// A class can inherit from any number of classes, abstract or not.
// When inheriting from multiple classes no class can share a field or method name.
new_class :: class #inherits(Test, Class2, ...) {
	init :: proc() {
		// Inherited constructors must be called explicitly.
		Test.init(3.5)
		Class2.init()
	},

	sub_a :: proc() {}, // <-- Not allowed as Test already defines a 'sub_a' method.
}

t3: new_class
// You can access the fields of an inherited class as if it was a direct member of the class.
t3.a = 2
t3.sub_a(5)

// Odin
new_class :: struct {
	using base___Test: Test,
	using base___Class2: Class2,
}

new_class___init :: proc(this: ^new_class) {
	Test___init(&this.base___Test, 3.5)
	Class2___init(&this.base___Class2)
}

t3: new_class
new_class___init(&t3)
// Since new_class doesn't define a destructor no uninit call is added.

t3.a = 2

Test___sub_a(&t3.base___Test, 5)

// OOdin
// An abstract class is a class which acts like a template that can't be instantiated.
// The '#abstract' tag is used to mark a class as abstract
abs_class :: class #abstract {
	f1: f32,
	f2: i32,

	init :: proc(f1: f32, f2: i32) {
		this.f1 = f1
		this.f2 = f2
	},

	// Unlike normal classes abstract classes don't have to provide
	// a function body for all their methods with the exception of
	// (de)constructors which must have a body if they are defined
	abs_method :: proc(), // Note I might change this to require the '#abstract' tag
}

// You can then inherit from the abstract class
my_class :: class #inherits(abs_class) {
	init :: proc() {
		abs_class.init(3.0, 20)
	},

	// You must define a method body for any inherited abstract methods.
	abs_method :: proc() {
		// Do something
	},
}

// An abstract class can also inherit from another abstract class.
// When an abstract class inherits another abstract class the inheritor
// doesn't have to provide a definition for the base classes abstract methods.
abs_2_class :: class #abstract #inherits(abs_class) {}

// Odin
abs_class :: struct {
	f1: f32,
	f2: i32,
}

abs_class___init :: proc(this: ^abs_class, f1: f32, f2: i32) {
	this.f1 = f1
	this.f2 = f2
}

my_class :: struct {
	using base___abs_class: abs_class,
}

my_class___init :: proc(this: ^my_class) {
	abs_class___init(&this.base___abs_class, 3.0, 20)
}

my_class___abs_method :: proc(this: ^my_class) {
	// Do something
},

abs_2_class :: struct {
	using base___abs_class: abs_class,
}

// OOdin
// Classes support parametric polymorphism (parapoly).
parapoly_class :: class($T: typeid) {
	field1: T,
}

parapoly: parapoly_class(i32)

// Odin
parapoly_class :: struct($T: typeid) {
	field1: T,
}

parapoly: parapoly_class(i32)

/*
	For now this concludes the intended syntax and features of OOdin
	however there is room to add more advanced OOP concepts.

	I intentially haven't added interfaces as I don't see what
	an interface offers that an abstract class doesn't.
*/
